{% extends "base.peb" %}

{% block title %}Online Editor - Tiny Game Engine{% endblock %}

{% block meta %}
    <!-- SEO -->
    <meta name="description" content="Try the Tiny game engine directly in your browser. Interactive code editor with Lua game examples - no installation required.">
    <meta name="robots" content="index, follow">

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="Online Editor - Tiny Game Engine">
    <meta property="og:description" content="Try the Tiny game engine directly in your browser. Interactive code editor with Lua game examples - no installation required.">
    <meta property="og:url" content="https://minigdx.github.io/tiny/editor.html">
    <meta property="og:image" content="https://minigdx.github.io/tiny/sample/favicon.png">
{% endblock %}

{% block pageStyles %}
    <style>
        .editor-hero {
            padding: 64px 24px 32px;
            text-align: center;
        }
        .editor-hero__title {
            font-size: 5rem; line-height: 1; text-transform: uppercase;
            color: var(--pink);
            filter: drop-shadow(4px 4px 0 var(--yellow));
        }
        .editor-hero__subtitle {
            font-size: 1.35rem; font-weight: 500; color: #64748b;
            max-width: 600px; margin: 16px auto 0;
        }

        .editor-wrapper {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px 64px;
        }

        /* -- tiny-web-editor styles */
        .tiny-button {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 8px 16px;
            background-color: #ff0080; color: white;
            text-align: center; text-decoration: none;
            font-weight: bold; font-size: 0.9em;
            border: none; border-radius: 4px; cursor: pointer;
            font-family: "Source Code Pro", monospace;
            transition: background-color 0.2s ease-in-out, transform 0.1s ease;
        }
        .tiny-button, .tiny-button:link, .tiny-button:visited { color: white; text-decoration: none; }
        .tiny-button:hover, .tiny-button:focus { background-color: #d4006b; color: white; outline: none; }
        .tiny-button svg { width: 16px; height: 16px; flex-shrink: 0; }

        .tiny-toolbar {
            width: 100%; min-height: 48px; padding: 4px 12px;
            border-radius: 10px 10px 0 0;
            background: #eef0f2; border: 1px solid #e0e0e0; border-bottom: none;
            display: flex; align-items: center;
        }
        .tiny-container {
            display: flex; width: 100%;
            border: 1px solid #e0e0e0; border-radius: 0 0 10px 10px;
            overflow: hidden; background: #f8f9fa;
        }
        .tiny-canvas {
            border: none; border-right: 1px solid #e0e0e0; cursor: none;
            flex: 1 1 auto; max-height: 512px; max-width: 512px;
        }
        .tiny-textarea:focus { outline: none; }
        .tiny-textarea {
            flex: 2 1 auto; display: block; min-height: 512px;
            padding-left: 48px; padding-top: 12px; padding-bottom: 12px;
            counter-reset: line; width: 100%;
            font-family: "Source Code Pro", monospace;
            font-size: 0.88rem; line-height: 1.7;
            color: #333; background: #f8f9fa; resize: none;
        }
        .tiny-textarea div {
            display: block; position: relative; white-space: pre-wrap; min-height: 1em;
        }
        .tiny-textarea div::before {
            color: #c0c0c0; content: counter(line); counter-increment: line;
            position: absolute; right: calc(100% + 16px); font-size: 0.8em;
        }
        .tiny-status-bar { width: 100%; height: 1px; }
        .tiny-status-bar-progress { height: 100%; width: 100%; }
        .tiny-status-editing { background-color: #e89830; }
        .tiny-status-loaded { background-color: #4caf50; }

        /* -- Syntax highlighting */
        .code_keyword { color: #7c3aed; }
        .code_comment { color: #9ca3af; font-style: italic; }
        .code_string { color: #16a34a; }
        .code_number { color: #ea580c; }

        @media (max-width: 960px) {
            .editor-hero__title { font-size: 3.5rem; }
        }
        @media (max-width: 600px) {
            .editor-hero__title { font-size: 2.5rem; }
        }
    </style>
{% endblock %}

{% block content %}
        <section class="editor-hero">
            <h1 class="editor-hero__title font-display">Editor</h1>
            <p class="editor-hero__subtitle">
                Write, run, and experiment with Lua games directly in your browser. No installation required.
            </p>
        </section>

        <div class="editor-wrapper">
            <tiny-editor style="display: none;" sprite="resources/tiny-dungeon.png" mode="editor"
                examples='[{"name":"Empty Project","code":"ZnVuY3Rpb24gX2luaXQoKQoKZW5kCgpmdW5jdGlvbiBfdXBkYXRlKCkKCmVuZAoKZnVuY3Rpb24gX2RyYXcoKQoKZW5k"},{"name":"Tracking the player mouse","code":""},{"name":"Waving letters","code":""},{"name":"AABB Collision","code":""},{"name":"Control sprite move","code":""},{"name":"Bouncing Bat","code":""},{"name":"Perlin and dither","code":""}]'>
function _init()

end

function _update()

end

function _draw()

end
            </tiny-editor>
        </div>
{% endblock %}

{% block pageScripts %}
<script type="module" crossorigin src="./tiny-web-editor.js"></script>
{% endblock %}
